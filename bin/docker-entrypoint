#!/bin/bash -e

APP_USER="${USERNAME:-rails_api_base}"

ensure_active_storage_dirs() {
  mkdir -p storage tmp/storage
  if [ "$(id -u)" = "0" ]; then
    chown -R "${USER_UID:-1000}:${USER_GID:-1000}" storage tmp/storage
  fi
}

# Fix Active Storage permissions when the container starts as root, then continue
# as the unprivileged app user for the actual command.
if [ "$1" != "--as-app-user" ]; then
  ensure_active_storage_dirs
  if [ "$(id -u)" = "0" ]; then
    exec runuser -u "${APP_USER}" -- "$0" --as-app-user "$@"
  fi
else
  shift
fi

cleanup_stale_server_pid() {
  local pidfile="tmp/pids/server.pid"

  if [ ! -f "${pidfile}" ]; then
    return
  fi

  local pid
  pid="$(cat "${pidfile}" 2>/dev/null || true)"

  if [ -z "${pid}" ] || ! kill -0 "${pid}" 2>/dev/null; then
    rm -f "${pidfile}"
  fi
}

# If running the rails server then create or migrate existing database
if ([ "${1}" == "./bin/rails" ] && [ "${2}" == "server" ]) || [ "${1}" == "./bin/dev" ] || [[ $@ == *"bundle exec puma"* ]]; then
  cleanup_stale_server_pid
  ./bin/rails db:prepare
fi

if [ "${1}" == "./bin/rspec" ] || [ "${RAILS_ENV}" == "test" ]; then
  ./bin/rails db:test:prepare
fi

exec "${@}"
