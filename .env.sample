AWS_ACCESS_KEY_ID=
AWS_BUCKET_REGION=
AWS_SECRET_ACCESS_KEY=
DOCKER_ENABLED=false
NEW_RELIC_API_KEY=api_key
NEW_RELIC_APP_NAME='rails_api_base - development'
PASSWORD_RESET_URL=http://127.0.0.1:3001/en/reset-password
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
SENDGRID_API_KEY=
SERVER_HOST=localhost
S3_BUCKET_NAME=
# AI resume parsing (resume upload onboarding). Pick the provider with
# RESUME_PARSER_PROVIDER (anthropic | gemini); each needs its own API key.
RESUME_PARSER_PROVIDER=gemini
ANTHROPIC_API_KEY=
# Google AI Studio key for the Gemini parser (gemini-2.5-flash-lite).
GEMINI_API_KEY=
# Production (Render): set SERVER_HOST to your Render hostname, e.g. resume-builder-api.onrender.com
# Profile photos persist across deploys only when S3 is configured (all four vars above).
# Without S3, Active Storage uses local disk which is ephemeral on Render.
# SECRET_KEY_BASE is generated automatically when using render.yaml
SWAGGER_USERNAME=username
SWAGGER_PASSWORD=password
CHAOTIC_ORDER=true
# --- Job Alerts / Telegram notifications ---
# Public base URL of the frontend; used to link job-alert messages back to the
# job detail page (e.g. {FRONTEND_URL}/en/jobs/123). Defaults to localhost:3001.
FRONTEND_URL=http://localhost:3001
# Bot token from @BotFather and the bot's username (without @).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Production webhook: public HTTPS URL of POST /api/v1/telegram/webhook and a
# random secret echoed back in the X-Telegram-Bot-Api-Secret-Token header.
# Register with `rake telegram:set_webhook`. Locally, run `rake telegram:poll` instead.
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=8d242104fa11ad375dfa36796026d260ebb1f7444d7c68b59638ca2a8fadc60d
